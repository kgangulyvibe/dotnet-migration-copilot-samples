@if (Request.IsAuthenticated)
{
    <ul class="navbar-nav ms-auto">
        <li class="nav-item">
            <span class="nav-link text-light">Hello, @User.Identity.Name!</span>
        </li>
        <li class="nav-item">
            @using (Html.BeginForm("SignOut", "Account", FormMethod.Post, new { id = "logoutForm", @class = "d-inline" }))
            {
                @Html.AntiForgeryToken()
                <button type="submit" class="nav-link btn btn-link text-light" style="cursor:pointer;">Sign out</button>
            }
        </li>
    </ul>
}
else
{
    <ul class="navbar-nav ms-auto">
        <li class="nav-item">
            <span class="nav-link text-light">Not signed in</span>
        </li>
    </ul>
}
